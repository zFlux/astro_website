---
// Redirect /prioritize to /prioritize/10 (default grid size)
const redirectPath = '/prioritize/10';
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="refresh" content={`0;url=${redirectPath}`} />
  <title>Redirecting…</title>
</head>
<body>
  <p>Redirecting to <a href={redirectPath}>Prioritization Grid (10 items)</a>…</p>
  <script is:inline>
    window.location.replace('/prioritize/10');
  </script>
</body>
</html>
